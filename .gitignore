# Rust
/target/
/.cargo/
*.rs.bk
# Cargo.lock IS tracked — this is a binary crate, not a library.
# Tracking it ensures reproducible builds for all contributors and CI.

# Swift / Xcode
gui/XMacApp/.build/
gui/XMacApp/DerivedData/
gui/staging/
*.xcuserstate
*.xcworkspace/xcuserdata/
.swiftpm/

# GNN / Python
gnn/__pycache__/
gnn/**/__pycache__/
gnn/*.pyc
gnn/**/*.pyc
gnn/.venv/
gnn/venv/
*.pt
*.pth
# Keep the pre-trained CoreML models — they're needed for the build
# gnn/XMacGNN.mlpackage        <-- intentionally tracked
# gnn/XMacMemoryGNN.mlpackage  <-- intentionally tracked
gnn/XMacGNN.previous*.mlpackage/

# Bundled CoreML model copied into Swift sources by build_app.sh
gui/XMacApp/Sources/XMacApp/Resources/

# macOS
.DS_Store
**/.DS_Store
.Spotlight-V100
.Trashes

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs / temp
*.log
/tmp/

# ═══════════════════════════════════════════════════════════════════════
# Personal / internal files — NEVER commit these
# ═══════════════════════════════════════════════════════════════════════

# Outreach and recruitment materials
outreach-emails/
outreach-emails/**
contributor-candidates.md

# Internal AI agent directives and working docs (not for public contributors)
NORTH_STAR_TRAINING.md
**/NORTH_STAR_TRAINING.md
TODO.md
NOTES.md
SCRATCH.md

# Personal notes and drafts
drafts/
drafts/**
*.draft
*.draft.md

# Secrets and credentials — never commit
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
*.token

# Local config that shouldn't be shared
.local/
*.local.toml
*.local.json
